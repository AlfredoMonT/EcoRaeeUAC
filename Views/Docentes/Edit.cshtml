@model EcoRaeeUac.Models.Docente

@{
    ViewData["Title"] = "Editar Docente";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="card-custom">
            <div class="p-3 border-bottom" style="background:var(--surface-bright)">
                <h4 class="font-headline-md mb-0 text-on-surface">
                    <span class="material-symbols-outlined" style="font-size:18px;">edit</span>
                    Editar Docente
                </h4>
            </div>
            <div class="p-4">
                <form asp-action="Edit">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger font-body-sm"></div>
                    <div class="mb-3">
                        <label asp-for="NombreCompleto" class="form-label font-label-uppercase text-on-surface-variant"></label>
                        <input asp-for="NombreCompleto" class="form-control" />
                        <span asp-validation-for="NombreCompleto" class="text-danger font-body-sm"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label font-label-uppercase text-on-surface-variant"></label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger font-body-sm"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Telefono" class="form-label font-label-uppercase text-on-surface-variant">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Especialidad" class="form-label font-label-uppercase text-on-surface-variant">Especialidad</label>
                        <input asp-for="Especialidad" class="form-control" />
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <span class="material-symbols-outlined" style="font-size:18px;">save</span>
                            Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
