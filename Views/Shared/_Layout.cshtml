<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoRAEE UAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
    <div class="d-flex min-vh-100" id="appWrapper">
        <!-- Mobile overlay -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebarMenu">
            <div class="d-flex align-items-center gap-3 px-3 mb-4 mt-3">
                <div class="d-flex align-items-center justify-content-center rounded-3 bg-primary text-on-primary" style="width:40px;height:40px;">
                    <span class="material-symbols-outlined fill">recycling</span>
                </div>
                <div>
                    <h1 class="font-headline-md text-primary m-0">EcoRAEE UAC</h1>
                    <p class="font-body-sm text-on-surface-variant m-0">Administración</p>
                </div>
            </div>
            <nav class="d-flex flex-column gap-2 flex-grow-1 px-2">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index" onclick="closeSidebar()">
                    <span class="material-symbols-outlined">dashboard</span>
                    Dashboard
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Campañas" ? "active" : "")"
                   asp-controller="Campañas" asp-action="Index" onclick="closeSidebar()">
                    <span class="material-symbols-outlined">eco</span>
                    Campañas Ambientales
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Participantes" ? "active" : "")"
                   asp-controller="Participantes" asp-action="Index" onclick="closeSidebar()">
                    <span class="material-symbols-outlined">groups</span>
                    Participantes
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Docentes" ? "active" : "")"
                   asp-controller="Docentes" asp-action="Index" onclick="closeSidebar()">
                    <span class="material-symbols-outlined">assignment_ind</span>
                    Docentes
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "MaterialEducativo" ? "active" : "")"
                   asp-controller="MaterialEducativo" asp-action="Index" onclick="closeSidebar()">
                    <span class="material-symbols-outlined">menu_book</span>
                    Material Educativo
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Recoleccion" ? "active" : "")"
                   asp-controller="Recoleccion" asp-action="Index" onclick="closeSidebar()">
                    <span class="material-symbols-outlined">recycling</span>
                    Recolección RAEE
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reportes" ? "active" : "")"
                   asp-controller="Reportes" asp-action="Index" onclick="closeSidebar()">
                    <span class="material-symbols-outlined">analytics</span>
                    Reportes e Impacto
                </a>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <div class="main-wrapper d-flex flex-column min-vh-100" id="mainWrapper">
            <!-- Topbar -->
            <header class="topbar d-flex justify-content-between align-items-center px-3 px-md-4 position-sticky top-0 z-2">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn p-1" type="button" onclick="toggleSidebar()" aria-label="Menú" style="line-height:1;">
                        <span class="material-symbols-outlined text-primary" style="font-size:28px;">menu</span>
                    </button>
                    <div class="d-md-none d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1;">recycling</span>
                        <span class="font-headline-md text-primary">EcoRAEE UAC</span>
                    </div>
                </div>
                <div class="d-none d-md-block"></div>
            </header>

            <!-- Page Content -->
            <main class="flex-grow-1 p-3 p-md-4 overflow-y-auto bg-background" style="min-height: calc(100vh - 64px);">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            if (window.innerWidth < 768) {
                document.getElementById('sidebarMenu').classList.toggle('show');
                document.getElementById('sidebarOverlay').classList.toggle('show');
            } else {
                document.getElementById('appWrapper').classList.toggle('sidebar-collapsed');
            }
        }
        function closeSidebar() {
            document.getElementById('sidebarMenu').classList.remove('show');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
