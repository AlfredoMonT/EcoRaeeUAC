@model EcoRaeeUac.Models.RecoleccionRaee

@{
    ViewData["Title"] = "Nueva Recolección";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="card-custom">
            <div class="p-3 border-bottom" style="background:var(--surface-bright);">
                <h4 class="font-headline-md mb-0 text-primary">
                    <span class="material-symbols-outlined" style="font-size:18px;">add_circle</span>
                    Registrar Nueva Recolección de RAEE
                </h4>
            </div>
            <div class="p-4">
                <form asp-action="Create">
                    <div class="mb-3">
                        <label asp-for="TipoResiduo" class="form-label font-body-sm text-on-surface-variant">Tipo de Residuo</label>
                        <select asp-for="TipoResiduo" class="form-select" required>
                            <option value="">Seleccione un tipo...</option>
                            <option value="Computadoras">Computadoras</option>
                            <option value="Monitores">Monitores</option>
                            <option value="Celulares">Celulares</option>
                            <option value="Impresoras">Impresoras</option>
                            <option value="Baterías">Baterías</option>
                            <option value="Otros">Otros</option>
                        </select>
                        <span asp-validation-for="TipoResiduo" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Cantidad" class="form-label font-body-sm text-on-surface-variant">Cantidad (en Kg)</label>
                        <input asp-for="Cantidad" class="form-control" type="number" step="0.01" placeholder="Ej: 15.50" required />
                        <span asp-validation-for="Cantidad" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LugarRecoleccion" class="form-label font-body-sm text-on-surface-variant">Lugar de Recolección</label>
                        <input asp-for="LugarRecoleccion" class="form-control" placeholder="Ej: Campus UAC - Pabellón A" required />
                        <span asp-validation-for="LugarRecoleccion" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Fecha" class="form-label font-body-sm text-on-surface-variant">Fecha de Recolección</label>
                        <input asp-for="Fecha" class="form-control" type="date" required />
                        <span asp-validation-for="Fecha" class="text-danger"></span>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <span class="material-symbols-outlined" style="font-size:18px;">save</span>
                            Guardar Recolección
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
