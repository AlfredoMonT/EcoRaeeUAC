@model EcoRaeeUac.Models.Participante

@{
    ViewData["Title"] = "Detalles del Participante";
}

<div class="row mt-4">
    <div class="col-md-8 offset-md-2">
        <div class="card-custom">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center" style="background:var(--surface-bright);">
                <h4 class="font-headline-md mb-0 text-on-surface">Detalles del Participante</h4>
                <a asp-action="Index" class="btn btn-outline-primary rounded-2 p-1">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span> Volver
                </a>
            </div>
            <div class="p-4">
                <dl class="row">
                    <dt class="col-sm-4 font-label-uppercase text-on-surface-variant">Nombre Completo</dt>
                    <dd class="col-sm-8 font-body-sm text-on-surface">@Model.NombreCompleto</dd>
                    <dt class="col-sm-4 font-label-uppercase text-on-surface-variant">Rol</dt>
                    <dd class="col-sm-8">
                        <span class="tag tag-primary">@Model.Rol</span>
                    </dd>
                    <dt class="col-sm-4 font-label-uppercase text-on-surface-variant">Documento</dt>
                    <dd class="col-sm-8 font-body-sm text-on-surface">@Model.DocumentoIdentidad</dd>
                    <dt class="col-sm-4 font-label-uppercase text-on-surface-variant">Campaña</dt>
                    <dd class="col-sm-8 font-body-sm">
                        <a asp-controller="Campañas" asp-action="Details" asp-route-id="@Model.CampañaAmbientalId" class="text-primary">
                            @Model.CampañaAmbiental?.Nombre
                        </a>
                    </dd>
                    <dt class="col-sm-4 font-label-uppercase text-on-surface-variant">Docente Vinculado</dt>
                    <dd class="col-sm-8 font-body-sm">
                        @if (Model.Docente != null)
                        {
                            <a asp-controller="Docentes" asp-action="Details" asp-route-id="@Model.DocenteId" class="text-primary">
                                @Model.Docente.NombreCompleto
                            </a>
                        }
                        else
                        {
                            <span class="text-on-surface-variant">—</span>
                        }
                    </dd>
                </dl>
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-2 p-1">
                        <span class="material-symbols-outlined" style="font-size:18px;">edit</span> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-primary rounded-2 p-1">
                        <span class="material-symbols-outlined" style="font-size:18px;">delete</span> Eliminar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
