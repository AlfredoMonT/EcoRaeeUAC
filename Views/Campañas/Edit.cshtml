@model EcoRaeeUac.Models.CampañaAmbiental

@{
    ViewData["Title"] = "Editar Campaña";
}

<div class="row mt-4">
    <div class="col-md-8 offset-md-2">
        <div class="card-custom">
            <div class="card-header d-flex align-items-center gap-2 p-3" style="background: var(--surface-bright); border-bottom: 1px solid var(--outline-variant);">
                <span class="material-symbols-outlined" style="font-size: 18px; color: var(--primary);">edit</span>
                <h4 class="font-headline-md mb-0 text-primary">Editar Campaña</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input asp-for="Id" type="hidden" />
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label font-body-sm text-on-surface-variant">Nombre de la Campaña</label>
                        <input asp-for="Nombre" class="form-control" required />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Fecha" class="form-label font-body-sm text-on-surface-variant">Fecha del Evento</label>
                            <input asp-for="Fecha" class="form-control" type="date" required />
                            <span asp-validation-for="Fecha" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Lugar" class="form-label font-body-sm text-on-surface-variant">Lugar</label>
                            <input asp-for="Lugar" class="form-control" required />
                            <span asp-validation-for="Lugar" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ResponsableId" class="form-label font-body-sm text-on-surface-variant">Docente Responsable</label>
                        <select asp-for="ResponsableId" class="form-select" required>
                            <option value="">Seleccione un docente...</option>
                            @foreach (var d in (List<Docente>)ViewBag.Docentes)
                            {
                                <option value="@d.Id">@d.NombreCompleto - @d.Especialidad</option>
                            }
                        </select>
                        <span asp-validation-for="ResponsableId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label font-body-sm text-on-surface-variant">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <span class="material-symbols-outlined" style="font-size: 18px;">arrow_back</span> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <span class="material-symbols-outlined" style="font-size: 18px;">save</span> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
